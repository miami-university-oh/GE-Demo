# pnpm local store & virtual store
.pnpm-store/
.pnpm/
node_modules/.modules.yaml
node_modules/.package-lock.json

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Optional package manager caches
.npm/
.yarn/
.yarn-integrity
jspm_packages/

# Output of `npm pack`
*.tgz


