# Machine IPs
HAAS_IP=192.168.1.50
HAAS_PORT=5051
UR5E_IP=192.168.1.15
UR5E_RTDE_PORT=30004
UR5E_DASHBOARD_PORT=29999
UR5E_SCRIPT_PORT=30001

# Camera IPs
AMCREST_IP=192.168.1.108
AMCREST_RTSP_USER=admin
AMCREST_RTSP_PASS=your_password_here

# CAM01 (RealSense L515 via host publisher)
CAM01_INGEST_TOKEN=change_this_token
# Publisher only: where the dashboard backend is reachable from the camera machine.
# Same machine: http://localhost:8000 — over WiFi: http://<server-ip>:8000
CAM01_INGEST_URL=http://localhost:8000

# Server config
BACKEND_PORT=8000
UR5E_HTTP_API_KEY=your_api_key_here

# Bridge polling intervals (seconds)
HAAS_POLL_INTERVAL=1.0
UR5E_POLL_INTERVAL=0.1
SIM_TICK_INTERVAL=1.5
RECONNECT_WAIT=5.0

# Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_dashboard_password_here
